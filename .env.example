# Variáveis de Ambiente - App de Saúde Mental

# Conexão com o banco de dados (Supabase / PostgreSQL)
# O DATABASE_URL é usado pelo Prisma Client para se conectar ao banco e fazer queries regulares.
# No Supabase, pegue a URL de "Session pooler" (porta 6543, normalmente) ou direto (5432).
DATABASE_URL="postgresql://user:password@host:port/postgres?pgbouncer=true"

# O DIRECT_URL é usado pelo Prisma CLI para rodar migrações.
# No Supabase, pegue a URL direta (porta 5432).
DIRECT_URL="postgresql://user:password@host:port/postgres"

# Outras variáveis de configuração
NEXT_PUBLIC_APP_URL="http://localhost:3000"

NEXT_PUBLIC_SUPABASE_URL="https://seu-projeto.supabase.co"

NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key-aqui"
