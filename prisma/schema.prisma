// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  PSYCHOLOGIST
}

model User {
  id             String       @id @default(uuid()) @db.Uuid
  email          String       @unique
  name           String
  role           Role         @default(PATIENT)
  doctorCode     String?      @unique
  psychologistId String?      @db.Uuid

  createdAt      DateTime     @default(now())
  
  emotionLogs    EmotionLog[]
  
  // Auto-relacionamento Paciente -> Psicólogo
  psychologist   User?        @relation("PsychologistToPatient", fields: [psychologistId], references: [id])
  patients       User[]       @relation("PsychologistToPatient")
}

model EmotionLog {
  id        String   @id @default(uuid()) @db.Uuid
  patientId String   @db.Uuid
  emotion   String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient   User     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}
